# Copy to `infra/.env` to override the compose defaults. All optional.
MONGO_USER=lametrader
MONGO_PASSWORD=lametrader
MONGO_DB=lametrader

# Host-port bindings. Defaults match the standard ports each service
# normally listens on; override here if you already have something on
# any of them (e.g. another Mongo on 27017).
MONGO_PORT=27017
API_PORT=3000
WEB_PORT=8080

# mongo-express (only used with `--profile tools`)
MONGO_EXPRESS_PORT=8081

# Connection string for tools running OUTSIDE docker (mongosh, `npm run api:dev`).
# The dockerized api reaches mongo as `mongo:27017` on the compose network and
# does not need this override.
# MONGODB_URI=mongodb://lametrader:lametrader@localhost:27017/lametrader?authSource=admin
