# Copy to `infra/.env` to override the compose defaults. All optional.
MONGO_USER=lametrader
MONGO_PASSWORD=lametrader
MONGO_DB=lametrader

# Host-port bindings — shifted off the 27017 / 3000 / 8080 defaults so the
# stack doesn't collide with other local Mongo / api / nginx projects. The
# container-internal ports stay standard (27017 / 3000 / 8080), so services
# reach each other on the compose network unchanged.
MONGO_PORT=28017
API_PORT=28000
WEB_PORT=28080

# mongo-express (only used with `--profile tools`)
MONGO_EXPRESS_PORT=28081

# Connection string for tools running OUTSIDE docker (mongosh, `npm run api:dev`).
# The dockerized api reaches mongo as `mongo:27017` on the compose network and
# does not need this override.
# MONGODB_URI=mongodb://lametrader:lametrader@localhost:28017/lametrader?authSource=admin
