{
  "name": "lametrader",
  "version": "0.0.0",
  "private": true,
  "description": "Quant trading platform: ingest market data, analyze, generate signals, backtest.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --build && npm run --workspaces --if-present typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:e2e": "vitest run --project e2e",
    "test:live": "vitest run --project live",
    "test:server": "npm run test -w @lametrader/server",
    "test:server:e2e": "npm run test:e2e -w @lametrader/server",
    "coverage": "vitest run --project unit --coverage",
    "check": "npm run typecheck && npm run lint && npm test && npm run test:server",
    "check:full": "npm run check && npm run test:e2e && npm run test:server:e2e",
    "server": "npm run start -w @lametrader/server",
    "web": "npm run dev -w @lametrader/web",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "infra:logs": "docker compose -f infra/docker-compose.yml logs -f",
    "infra:reset": "docker compose -f infra/docker-compose.yml down -v",
    "app:up": "docker compose -f infra/docker-compose.yml --profile app up -d --build",
    "app:down": "docker compose -f infra/docker-compose.yml --profile app down",
    "app:logs": "docker compose -f infra/docker-compose.yml --profile app logs -f",
    "app:logs:server": "docker compose -f infra/docker-compose.yml --profile app logs -f --no-log-prefix server | pino-pretty -i pid,hostname",
    "app:build": "docker compose -f infra/docker-compose.yml --profile app build"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@testcontainers/mongodb": "^12.0.3",
    "@types/node": "^25.9.4",
    "@vitest/coverage-v8": "^4.1.9",
    "pino-pretty": "^13.1.3",
    "testcontainers": "^12.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
