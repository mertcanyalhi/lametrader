{
  "name": "@lametrader/backend",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node --max-old-space-size=4096 dist/main.js",
    "start:dev": "tsc-watch --onSuccess \"node --max-old-space-size=4096 dist/main.js\"",
    "test": "jest --selectProjects unit",
    "test:e2e": "jest --selectProjects e2e --runInBand --forceExit"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "ioredis": "^5.11.1",
    "mongoose": "^9.7.3",
    "nanoid": "^3.3.12",
    "nestjs-pino": "^4.6.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ws": "^8.21.0",
    "yahoo-finance2": "^3.15.3"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.28",
    "@swc/core": "^1.15.43",
    "@swc/jest": "^0.2.39",
    "@testcontainers/mongodb": "^12.0.4",
    "@types/jest": "^30.0.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "tsc-watch": "^7.2.1"
  }
}
