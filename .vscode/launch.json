{
  "version": "0.2.0",
  "configurations": [
    {
      // Debug the NestJS backend: build with tsc, then run the compiled
      // dist/main.js. Sourcemaps map breakpoints back to src/**/*.ts.
      "type": "node",
      "request": "launch",
      "name": "Debug backend",
      "preLaunchTask": "npm: build - @lametrader/backend",
      "program": "${workspaceFolder}/packages/backend/dist/main.js",
      "cwd": "${workspaceFolder}/packages/backend",
      "outFiles": ["${workspaceFolder}/packages/backend/dist/**/*.js"],
      "console": "integratedTerminal",
      "sourceMaps": true,
      "skipFiles": ["<node_internals>/**"],
      "env": {
        "LOG_LEVEL": "trace"
      }
    }
  ]
}
